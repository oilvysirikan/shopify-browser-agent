PORT=4000
NODE_ENV=development

# Rails API
RAILS_API_URL=http://localhost:3000/api/v1

# Internal auth
WORKER_SHARED_TOKEN=change_me_worker_token
ADSCALE_API_KEY=change_me_adscale_api_key

# Shopify
SHOPIFY_API_KEY=your_key
SHOPIFY_API_SECRET=your_secret
SHOPIFY_STORE_URL=alindadecor.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_token
SHOPIFY_API_VERSION=2024-10
SHOPIFY_ALLOWED_TOPICS=products/update,products/create,products/delete
SHOPIFY_WEBHOOK_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379/0

# Facebook
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_ACCESS_TOKEN=your_access_token
FACEBOOK_CATALOG_ID=your_catalog_id
FACEBOOK_BRAND=ALINDA DECOR
FACEBOOK_BASE_PRODUCT_URL=https://alindadecor.com/products

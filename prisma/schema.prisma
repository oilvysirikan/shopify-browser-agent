// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tenant/Shop Configuration
model Tenant {
  id        String   @id @default(cuid())
  shop      String   @unique // my-store.myshopify.com
  plan      String   @default("free") // free, basic, premium, enterprise
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  usage   Usage[]
  audits  AuditLog[]
}

// Usage tracking per tenant
model Usage {
  id          String   @id @default(cuid())
  tenantId    String
  date        DateTime @default(now())
  endpoint    String
  model       String
  tokensUsed  Int
  cost        Float
  success     Boolean
  metadata    Json?
  
  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  
  @@index([tenantId, date])
}

// Audit logging
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  action      String   // e.g., "GENERATE_DESCRIPTION", "UPDATE_SETTINGS"
  status      String   // success, failed, partial
  resourceId  String?  // e.g., product ID
  metadata    Json?    // Additional context
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  
  @@index([tenantId, createdAt])
}

// API Key management for internal services
model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?

  @@index([key])
}

// Chat Platform Integrations
model ChatPlatform {
  id        String   @id @default(cuid())
  tenantId  String
  platform  String   // line, whatsapp, facebook
  isActive  Boolean  @default(true)
  config    Json     // API keys, tokens, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Customer Conversations
model Conversation {
  id          String   @id @default(cuid())
  tenantId    String
  platform    String   // line, whatsapp, web
  customerId  String   // platform-specific user ID
  customerName String?
  messages    Json[]   // Array of message objects
  cart        Json?    // Current cart state
  status      String   @default("active") // active, closed, pending
  lastMessageAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([tenantId, platform])
  @@index([customerId])
}

// AI Pricing Rules
model PricingRule {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String?
  name        String
  type        String   // dynamic, competitor, demand, time
  conditions  Json     // Rule conditions
  adjustments Json     // Price adjustments
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Marketing Campaigns
model MarketingCampaign {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        String   // email, sms, push
  target      String   // all, new, returning
  content     String
  status      String   @default("draft")
  scheduledAt DateTime?
  sentAt      DateTime?
  metrics     Json?    // opens, clicks, conversions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AI Autonomous Tasks
model AutonomousTask {
  id          String   @id @default(cuid())
  tenantId    String
  type        String   // pricing, marketing, inventory
  status      String   @default("pending")
  priority    String   @default("medium")
  data        Json     // Task parameters
  result      Json?    // Task result
  executedAt  DateTime?
  createdAt   DateTime @default(now())
}

# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.css text
*.html text
*.js text
*.json text
*.md text
*.ts text
*.tsx text
*.yml text

# Declare files that will always have CRLF line endings on checkout.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.sh text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.dmg binary
*.pkg binary
*.exe binary
*.dll binary
*.so binary
*.o binary
*.obj binary
*.lib binary
*.a binary
*.pyc binary
*.pyo binary
*.pyd binary
*.class binary
*.jar binary
*.war binary
*.ear binary
*.xpi binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.sql binary
*.db-journal binary
*.sublime-workspace binary
*.sublime-project binary

# Ignore all test fixtures and snapshots
__tests__/**/__fixtures__/** binary
__tests__/**/__snapshots__/** binary
*.snap binary

# Special handling for package.json to ensure it's treated as text but with LF line endings
package.json text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf

# Special handling for .gitignore and .gitattributes to ensure they use LF line endings
.gitignore text eol=lf
.gitattributes text eol=lf

{
  "name": "my-project",
  "main": "src/cloudflare/index.ts",
  "compatibility_date": "2025-02-11",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sv9-platform-db",

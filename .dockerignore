# flyctl launch added from gemini-cli/.gitignore
# API keys and secrets
gemini-cli/**/.env
gemini-cli/**/.env~

# gemini-cli settings
# We want to keep the .gemini in the root of the repo and ignore any .gemini
# in subdirectories. In our root .gemini we want to allow for version control
# for subcommands.
gemini-cli/**/**/.gemini
!gemini-cli/.gemini
gemini-cli/**/.gemini/*
!gemini-cli/**/.gemini/config.yaml
!gemini-cli/**/.gemini/commands
!gemini-cli/**/.gemini/skills
!gemini-cli/**/.gemini/settings.json

# Note: .gemini-clipboard/ is NOT in gitignore so Gemini can access pasted images

# Dependency directory
gemini-cli/**/node_modules
gemini-cli/**/bower_components

# Editors
gemini-cli/**/.idea
gemini-cli/**/*.iml

# OS metadata
gemini-cli/**/.DS_Store
gemini-cli/**/Thumbs.db

# TypeScript build info files
gemini-cli/**/*.tsbuildinfo

# Ignore built ts files
gemini-cli/**/dist

# Docker folder to help skip auth refreshes
gemini-cli/**/.docker

gemini-cli/**/bundle

# Test report files
gemini-cli/**/junit.xml
gemini-cli/**/packages/*/coverage

# Generated files
gemini-cli/**/packages/cli/src/generated
gemini-cli/**/packages/core/src/generated
gemini-cli/**/.integration-tests
gemini-cli/**/packages/vscode-ide-companion/*.vsix
gemini-cli/**/packages/cli/download-ripgrep*

# GHA credentials
gemini-cli/**/gha-creds-*.json

# Log files
gemini-cli/**/patch_output.log

gemini-cli/**/.genkit
gemini-cli/**/.gemini-clipboard
gemini-cli/**/.eslintcache
gemini-cli/**/evals/logs

# flyctl launch added from gemini-cli/.husky/_/.gitignore
gemini-cli/.husky/_/**/*


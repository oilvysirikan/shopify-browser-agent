{
  "name": "shopify-browser-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --port 3001",
    "build:frontend": "vite build && node scripts/replace-env.js",
    "dev:backend": "tsx watch src/index.ts",
    "dev": "concurrently -n 'backend,frontend' -c 'bgBlue.bold,bgGreen.bold' \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "preview": "vite preview --port 3000",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "check:ui": "node --loader tsx scripts/check-ui.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "test:prisma": "ts-node scripts/test-prisma.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "@shopify/app-bridge-react": "^3.7.9",
    "@shopify/app-bridge-utils": "^3.5.1",
    "@shopify/polaris": "^10.40.0",
    "@shopify/shopify-api": "^7.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "morgan": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reflect-metadata": "^0.2.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@bull-board/api": "^5.10.0",
    "@bull-board/express": "^5.10.0",
    "@shopify/polaris-icons": "^6.11.0",
    "@shopify/polaris-tokens": "^6.6.0",
    "@types/basic-auth": "^1.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^3.15.9",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.17.9",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^18.17.5",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^3.0.14",
    "@types/passport-local": "^1.0.40",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.8",
    "@types/validator": "^13.11.8",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "@vitejs/plugin-react": "^4.0.4",
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "prisma": "^4.16.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.6",
    "tsx": "^3.12.3",
    "typescript": "^5.1.6",
    "vite": "^4.4.9",
    "vite-tsconfig-paths": "^4.2.0"
  },
  "resolutions": {
    "cross-spawn": "^7.0.3",
    "form-data": "^4.0.0",
    "graphql": "^16.8.1",
    "js-yaml": "^4.1.0",
    "ws": "^8.17.0",
    "zod": "^3.22.4"
  }
}
